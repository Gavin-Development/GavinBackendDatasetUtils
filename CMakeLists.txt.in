cmake_minimum_required(VERSION 3.17)
project(dependencies-download)

include(ExternalProject)
ExternalProject_Add(pybind11
        GIT_REPOSITORY    https://github.com/pybind/pybind11.git
        GIT_TAG           v2.7
        SOURCE_DIR        "${CMAKE_CURRENT_BINARY_DIR}/pybind11-src"
        BINARY_DIR        "${CMAKE_CURRENT_BINARY_DIR}/pybind11-build"
        CONFIGURE_COMMAND ""
        BUILD_COMMAND     ""
        INSTALL_COMMAND   ""
        TEST_COMMAND      ""
        )
ExternalProject_Add(googletest
        GIT_REPOSITORY    https://github.com/google/googletest.git
        GIT_TAG           release-1.11.0
        SOURCE_DIR        "${CMAKE_CURRENT_BINARY_DIR}/googletest-src"
        BINARY_DIR        "${CMAKE_CURRENT_BINARY_DIR}/googletest-build"
        CONFIGURE_COMMAND ""
        BUILD_COMMAND     ""
        INSTALL_COMMAND   ""
        TEST_COMMAND      ""
        )
ExternalProject_Add(SubwordTextEncoder
        GIT_REPOSITORY    https://github.com/Gavin-Development/CPP-SubwordTextEncoder.git
        GIT_TAG           master
        SOURCE_DIR        "${CMAKE_CURRENT_BINARY_DIR}/SubwordTextEncoder-src"
        BINARY_DIR        "${CMAKE_CURRENT_BINARY_DIR}/SubwordTextEncoder-build"
        CONFIGURE_COMMAND ""
        BUILD_COMMAND     ""
        INSTALL_COMMAND   ""
        TEST_COMMAND      ""
        )